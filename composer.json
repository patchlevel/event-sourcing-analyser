{
    "name": "patchlevel/event-sourcing-analyser",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "phpstan/phpstan": "^2.1",
        "alom/graphviz": "^2.0"
    },
    "require-dev": {
        "patchlevel/event-sourcing": "^3.8",
        "symfony/http-kernel": "^7.0.0 || ^8.0.0",
        "phpunit/phpunit": "^13.0",
        "patchlevel/coding-standard": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Patchlevel\\EventSourcingAnalyser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Patchlevel\\EventSourcingAnalyser\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
